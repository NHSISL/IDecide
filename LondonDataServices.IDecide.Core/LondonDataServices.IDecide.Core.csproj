	<ItemGroup>
		<InternalsVisibleTo Include="LondonDataServices.IDecide.Core.Tests.Unit" />
		<InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Migrations\" />
